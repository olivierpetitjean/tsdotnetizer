{
  "name": "tsdotnetizer",
  "version": "1.0.0",
  "description": "A TypeScript library that brings .NET Framework APIs and patterns to JavaScript/TypeScript",
  "author": "Olivier Petitjean",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olivierpetitjean/tsdotnetizer.git"
  },
  "bugs": {
    "url": "https://github.com/olivierpetitjean/tsdotnetizer/issues"
  },
  "homepage": "https://github.com/olivierpetitjean/tsdotnetizer#readme",
  "keywords": [
    "typescript",
    "dotnet",
    "linq",
    "csharp",
    "net",
    "collections",
    "extensions",
    "datetime"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
